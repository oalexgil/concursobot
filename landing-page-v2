<script>
// ── CONFIG — substituir antes de publicar ──────────────────
const SUPA_URL = 'https://bimxrblklisfhfevcbbm.supabase.co/rest/v1/';
const SUPA_KEY = 'sb_publishable_8ygVkBAfy9sg0Pob6PBL_g_FKK2Gzmb';
// ──────────────────────────────────────────────────────────

// Checkbox interativo
document.querySelectorAll('.check-opt').forEach(el => {
  el.addEventListener('click', () => {
    const cb = el.querySelector('input');
    cb.checked = !cb.checked;
    el.classList.toggle('on', cb.checked);
    el.querySelector('.check-mark').textContent = cb.checked ? '✓' : '';
  });
});

// Tag toggle
document.querySelectorAll('.tag').forEach(t => {
  t.addEventListener('click', () => t.classList.toggle('on'));
});

// Máscara de telefone
document.getElementById('tel').addEventListener('input', e => {
  let v = e.target.value.replace(/\D/g,'').slice(0,11);
  if (v.length > 2) v = '(' + v.slice(0,2) + ') ' + v.slice(2);
  if (v.length > 10) v = v.slice(0,10) + '-' + v.slice(10);
  e.target.value = v;
});

function showErr(id, show) {
  document.getElementById('e-' + id).classList.toggle('show', show);
}

function validar() {
  let ok = true;
  const nome = document.getElementById('nome').value.trim();
  showErr('nome', !nome); if (!nome) ok = false;

  const tel = document.getElementById('tel').value.replace(/\D/g,'');
  const telOk = tel.length >= 10;
  showErr('tel', !telOk); if (!telOk) ok = false;

  const tipos = [...document.querySelectorAll('#tipos input:checked')];
  showErr('tipos', !tipos.length); if (!tipos.length) ok = false;

  const area = document.getElementById('area').value.trim();
  showErr('area', !area); if (!area) ok = false;

  const estado = document.getElementById('estado').value;
  showErr('estado', !estado); if (!estado) ok = false;

  const fmts = [...document.querySelectorAll('#formatos .tag.on')];
  showErr('fmt', !fmts.length); if (!fmts.length) ok = false;

  const lgpd = document.getElementById('lgpd').checked;
  showErr('lgpd', !lgpd); if (!lgpd) ok = false;

  return ok;
}

async function enviar() {
  if (!validar()) return;
  const btn = document.getElementById('btn');
  btn.disabled = true;
  btn.classList.add('loading');

  const tel = document.getElementById('tel').value.replace(/\D/g,'');
  const tipos = [...document.querySelectorAll('#tipos input:checked')].map(e => e.value);
  const fmts = [...document.querySelectorAll('#formatos .tag.on')].map(t => t.dataset.v);

  const payload = {
    nome: document.getElementById('nome').value.trim(),
    telefone: '55' + tel,
    area: document.getElementById('area').value.trim(),
    estado: document.getElementById('estado').value,
    formato: fmts,
    filtro_edital_aberto: tipos.includes('edital_aberto'),
    filtro_inscricao_aberta: tipos.includes('inscricao_aberta'),
    ativo: true
  };

  try {
    const r = await fetch(SUPA_URL + '/rest/v1/usuarios', {
      method: 'POST',
      headers: {
        'Content-Type': 'application/json',
        'apikey': SUPA_KEY,
        'Authorization': 'Bearer ' + SUPA_KEY,
        'Prefer': 'return=minimal'
      },
      body: JSON.stringify(payload)
    });
    if (r.ok || r.status === 201 || r.status === 409) {
      document.getElementById('form-body').style.display = 'none';
      document.getElementById('ok').style.display = 'block';
    } else { throw new Error(r.status); }
  } catch {
    alert('Erro ao cadastrar. Tente novamente.');
    btn.disabled = false;
    btn.classList.remove('loading');
  }
}
</script>
